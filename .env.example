# Copy to .env and fill in. All variables use the HS_ prefix.

# --- Server ---
HS_HOST=0.0.0.0
HS_PORT=8410

# --- Auth (first run creates this user) ---
HS_USERNAME=admin
HS_PASSWORD=change-me
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
HS_SESSION_SECRET=

# --- Anthropic (LLM features: intake chat, desire scoring, area narratives) ---
HS_ANTHROPIC_API_KEY=

# --- Telegram alerts (create a bot with @BotFather, get chat id from @userinfobot) ---
HS_TELEGRAM_BOT_TOKEN=
HS_TELEGRAM_CHAT_ID=

# --- Email alerts (SMTP) ---
HS_SMTP_HOST=
HS_SMTP_PORT=587
HS_SMTP_USER=
HS_SMTP_PASSWORD=
HS_SMTP_FROM=
HS_SMTP_TO=

# --- Free API keys ---
# openrouteservice.org (free tier) — commute isochrones/travel times
HS_ORS_API_KEY=

# --- Scraping ---
HS_SCRAPE_ENABLED=true
HS_PLAYWRIGHT_FALLBACK=false
